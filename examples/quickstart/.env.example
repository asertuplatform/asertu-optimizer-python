# Tenant API key for event ingestion (required for track_event.py)
ASERTU_TENANT_API_KEY=your-tenant-api-key

# JWT token for tenant-scoped reads (required for read_analytics.py)
ASERTU_BEARER_TOKEN=your-jwt-token

# Tenant ID for tenant-scoped reads (required for read_analytics.py)
ASERTU_TENANT_ID=your-tenant-id
